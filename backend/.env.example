# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA commitar o arquivo ".env" (apenas este .env.example) em um repositorio.

# --- Oracle ---
ORACLE_USER=
ORACLE_PASSWORD=
# Formato host:porta/service_name (ex: 10.0.0.5:1521/ORCL) ou um DSN completo (TNS).
ORACLE_DSN=

# Diretorio onde o Oracle Instant Client foi extraido (modo "thick", necessario
# para Oracle 11g ou mais antigo). Deixe em branco se o Oracle for 12c+ e o
# modo "thin" (sem client) funcionar - o backend detecta e cai para thin
# automaticamente se ORACLE_CLIENT_LIB_DIR estiver vazio.
#
# Rodando via Docker (docker-compose.yml deste projeto): use
# /opt/oracle/instantclient - e o caminho onde o Dockerfile ja instala o
# Instant Client dentro da imagem, nao precisa instalar nada no host.
#
# Rodando direto no host (sem Docker): aponte para onde voce extraiu o
# Instant Client manualmente, ex: /opt/oracle/instantclient_19_23
ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient

ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# --- Cache ---
# Tempo (segundos) que o resultado de cada view fica em cache em memoria por
# data de referencia. Os dados de uma DATA_REFERENCIA especifica nao mudam
# depois de calculados pelo ETL do Oracle (cada dia e escrito uma vez), entao
# um TTL de 24h (86400s, default) e seguro e evita reconsultar o Oracle varias
# vezes ao longo do mesmo dia - a bridge geral sozinha pode levar dezenas de
# segundos com cache frio.
CACHE_TTL_SECONDS=86400

# TTL curto (segundos) so para a lista de "datas disponiveis" - precisa ser
# curto para o app perceber rapido quando o ETL publica um novo dia (o
# warm-up diario abaixo tambem forca essa atualizacao no horario configurado).
DATES_CACHE_TTL_SECONDS=600

# Horario (hora e minuto, 0-23 / 0-59) do job diario que aquece o cache do
# dia mais recente, disparando em segundo plano as mesmas consultas que o
# dashboard faz - assim a primeira pessoa a abrir o dashboard de manha ja
# encontra tudo pronto. Ajuste para logo depois do ETL noturno do Oracle
# terminar de publicar o novo dia.
CACHE_WARMUP_HOUR=8
CACHE_WARMUP_MINUTE=0

# --- API ---
# Origens permitidas para CORS (separadas por virgula). Ex para o frontend
# rodando localmente com Vite: http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Schema/owner das views no Oracle
ORACLE_SCHEMA=EPORTAL
