# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA commitar o arquivo ".env" (apenas este .env.example) em um repositorio.

# --- Oracle ---
ORACLE_USER=
ORACLE_PASSWORD=
# Formato host:porta/service_name (ex: 10.0.0.5:1521/ORCL) ou um DSN completo (TNS).
ORACLE_DSN=

# Diretorio onde o Oracle Instant Client foi extraido (modo "thick", necessario
# para Oracle 11g ou mais antigo). Deixe em branco se o Oracle for 12c+ e o
# modo "thin" (sem client) funcionar - o backend detecta e cai para thin
# automaticamente se ORACLE_CLIENT_LIB_DIR estiver vazio.
#
# Rodando via Docker (docker-compose.yml deste projeto): use
# /opt/oracle/instantclient - e o caminho onde o Dockerfile ja instala o
# Instant Client dentro da imagem, nao precisa instalar nada no host.
#
# Rodando direto no host (sem Docker): aponte para onde voce extraiu o
# Instant Client manualmente, ex: /opt/oracle/instantclient_19_23
ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient

ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# --- Cache ---
# Tempo (segundos) que o resultado de cada view fica em cache em memoria por
# data de referencia. Os dados de uma DATA_REFERENCIA ja carregada nao mudam,
# entao um valor alto (ex. 1800 = 30 min) e seguro e acelera bastante a UI.
CACHE_TTL_SECONDS=1800

# --- API ---
# Origens permitidas para CORS (separadas por virgula). Ex para o frontend
# rodando localmente com Vite: http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Schema/owner das views no Oracle
ORACLE_SCHEMA=EPORTAL
